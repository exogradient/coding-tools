#!/bin/bash
# Open hq dashboard — deduplicates tabs after space switch
open "http://localhost:7391/"
sleep 0.3
osascript -e '
tell application "Google Chrome"
  set found to false
  repeat with w in windows
    set i to 0
    repeat with t in tabs of w
      set i to i + 1
      if URL of t starts with "http://localhost:7391" then
        if found then
          close t
        else
          set found to true
          set active tab index of w to i
          set index of w to 1
        end if
      end if
    end repeat
  end repeat
end tell' 2>/dev/null
